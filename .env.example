# API Key for generating short plain-english explanations of anomalies
# You can obtain a free tier key for Gemini at https://aistudio.google.com/
GEMINI_API_KEY="your_api_key_here"

# Database URL (optional — defaults to SQLite at data/forecast.db)
# For PostgreSQL: DATABASE_URL="postgresql://user:password@localhost/forecast_db"
DATABASE_URL="sqlite:///data/forecast.db"
